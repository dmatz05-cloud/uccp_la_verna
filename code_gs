// Get announcements
function getAnnouncements() {
  const sheet = SpreadsheetApp.openById(DB_ID).getSheetByName("Announcements");
  if (!sheet) return [];

  const data = sheet.getDataRange().getValues();
  if (data.length <= 1) return [];

  // Skip header row and filter Active announcements
  const announcements = data.slice(1)
    .filter(row => row[3] && row[3].toString().trim().toLowerCase() === "active")
    .map(row => {
      return [
        row[0] instanceof Date ? row[0].toISOString().split('T')[0] : row[0], // convert Date to YYYY-MM-DD
        row[1],
        row[2],
        row[3]
      ];
    });

  return announcements;
}

// Add new announcement from admin form
function addAnnouncement(data) {
  const sheet = SpreadsheetApp.openById(DB_ID).getSheetByName("Announcements");
  sheet.appendRow([data.date, data.title, data.content, data.status]);
  return "Announcement added successfully!";
}

